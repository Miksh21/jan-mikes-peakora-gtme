# Required
N8N_BASE_URL=https://your-n8n-instance.example.com
N8N_API_KEY=your-n8n-api-key

# Transport: stdio or sse
MCP_TRANSPORT=sse
MCP_PORT=3000

# OAuth (optional — leave blank to disable auth)
OAUTH_USER_EMAIL=
OAUTH_USER_PASSWORD=
OAUTH_JWT_SECRET=
OAUTH_BASE_URL=https://your-deployed-mcp-server.example.com
